<script setup lang="ts">
import { ref } from 'vue'
import { showDialog, showToast } from 'vant'

// ตั้งค่ายอดเงินเริ่มต้นเป็น $ 1,540.00 ตามที่พี่ต้องการ
const balance = ref(1540.00)
const showWithdraw = ref(false)
const showBankPicker = ref(false)

// ฟอร์มถอนเงิน 4 ช่อง
const withdrawForm = ref({
  name: '',
  bank: '',
  accountNumber: '',
  amount: '',
})

const bankColumns = [
  { text: 'กสิกรไทย' },
  { text: 'ไทยพาณิชย์' },
  { text: 'กรุงเทพ' },
  { text: 'กรุงไทย' },
  { text: 'ออมสิน' },
]

function onBankConfirm({ selectedOptions }: any) {
  withdrawForm.value.bank = selectedOptions[0].text
  showBankPicker.value = false
}

function handleWithdraw() {
  if (!withdrawForm.value.name || !withdrawForm.value.bank || !withdrawForm.value.accountNumber || !withdrawForm.value.amount) {
    showToast('กรุณากรอกข้อมูลให้ครบถ้วน')
    return
  }
  showDialog({
    title: 'ส่งคำขอสำเร็จ',
    message: 'ระบบกำลังตรวจสอบรายการถอนเงิน โปรดรอ 15-30 นาที',
  }).then(() => {
    showWithdraw.value = false
  })
}

function formatMoney(val: number) {
  return val.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,')
}
</script>

<template>
  <div class="main-page">
    <div class="header-nav">
      <span class="logo">TikTok<span class="red-text">Shop</span></span>
      <van-icon name="setting-o" size="22" />
    </div>

    <van-notice-bar
      left-icon="volume-o"
      text="ยินดีด้วยกับคุณบัญชี 089***45xx ถอนเงินสำเร็จ 15,000 บาท, คุณบัญชี 061***9xxx..."
      background="#fff"
      color="#ed6a0c"
    />

    <div class="balance-card">
      <div class="label">
        ยอดเงินคงเหลือ (USDT)
      </div>
      <div class="amount">
        $ {{ formatMoney(balance) }}
      </div>
      <div class="btn-group">
        <div class="btn-action white">
          เติมเงิน
        </div>
        <div class="btn-action red" @click="showWithdraw = true">
          ถอนเงิน
        </div>
      </div>
    </div>

    <van-grid :column-num="4" :border="false" class="menu-grid">
      <van-grid-item icon="notes-o" text="ประวัติงาน" />
      <van-grid-item icon="idcard" text="กระเป๋าเงิน" />
      <van-grid-item icon="friends-o" text="เชิญเพื่อน" />
      <van-grid-item icon="info-o" text="เกี่ยวกับเรา" />
    </van-grid>

    <div class="section-title">
      ภารกิจวันนี้
    </div>
    <div v-for="i in 3" :key="i" class="mission-card">
      <div class="m-content">
        <div class="m-icon-box">
          <van-icon name="shopping-cart" color="#fff" size="20" />
        </div>
        <div class="m-info">
          <div class="m-title">
            ภารกิจโปรโมทสินค้าที่ {{ i }}
          </div>
          <div class="m-sub">
            ค่าคอมมิชชั่น: 15% - 25%
          </div>
        </div>
      </div>
      <van-button size="small" type="danger" round @click="showWithdraw = true">
        รับงาน
      </van-button>
    </div>

    <van-popup v-model:show="showWithdraw" position="bottom" round closeable :style="{ height: '75%' }">
      <div class="popup-body">
        <h3 class="popup-title">
          ถอนเงิน
        </h3>
        <van-cell-group inset>
          <van-field v-model="withdrawForm.name" label="ชื่อ-นามสกุล" placeholder="กรอกชื่อจริง" input-align="right" />
          <van-field v-model="withdrawForm.bank" is-link readonly label="ธนาคาร" placeholder="เลือกธนาคาร" input-align="right" @click="showBankPicker = true" />
          <van-field v-model="withdrawForm.accountNumber" label="เลขบัญชี" placeholder="ระบุเลขบัญชี" type="digit" input-align="right" />
          <van-field v-model="withdrawForm.amount" label="จำนวนเงิน" placeholder="ระบุยอดที่ต้องการถอน" type="number" input-align="right" />
        </van-cell-group>

        <div class="withdraw-notice">
          * หมายเหตุ: การถอนเงินอาจใช้เวลา 15-30 นาทีในการตรวจสอบความถูกต้องของภารกิจ
        </div>

        <div style="padding: 20px;">
          <van-button color="#000" round block style="height: 48px; font-weight: bold;" @click="handleWithdraw">
            ยืนยันการถอนเงิน
          </van-button>
        </div>
      </div>
    </van-popup>

    <van-popup v-model:show="showBankPicker" position="bottom" round>
      <van-picker title="เลือกธนาคาร" :columns="bankColumns" @confirm="onBankConfirm" @cancel="showBankPicker = false" />
    </van-popup>

    <van-tabbar active-color="#fe2c55">
      <van-tabbar-item icon="home-o">
        หน้าแรก
      </van-tabbar-item>
      <van-tabbar-item icon="description-o">
        ภารกิจ
      </van-tabbar-item>
      <van-tabbar-item icon="contact-o">
        ข้อมูลส่วนตัว
      </van-tabbar-item>
    </van-tabbar>
  </div>
</template>

